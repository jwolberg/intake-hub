# IntakeHub configuration — copy to `.env`, fill in, then `docker compose up`.
#
#   cp .env.example .env
#
# `.env` is gitignored and auto-loaded by Docker Compose. Every value is optional;
# the defaults run the offline demo (mock inbox, offline Sheets stub, no network).
# To monitor your own Google Drive folder, set INBOX_PROVIDER=drive and the
# DRIVE_* values below, then start the stack WITH the poller:
# `docker compose --profile drive up -d --build`. To read a connected Gmail
# mailbox instead, set INBOX_PROVIDER=gmail and the GMAIL_* values, then
# `docker compose --profile gmail up -d --build`. To file to a real Google Sheet
# instead of the offline stub, set SHEETS_SPREADSHEET_ID (+ the same
# GOOGLE_APPLICATION_CREDENTIALS used for Drive, or a dedicated key). See
# docs/gmail-sheets-setup.md.

# ── LLM extraction ──────────────────────────────────────────────────────────
# Anthropic key for model-derived extraction/confidence. Required in practice for
# Drive/Gmail monitoring: real receipts have no structured block, so without a
# key every invoice extracts blank and holds. Leave empty to use the offline
# stand-in (only parses the controlled sample PDFs).
ANTHROPIC_API_KEY=

# ── Inbox source ────────────────────────────────────────────────────────────
# mock  = offline demo set (default)
# drive = monitor a Google Drive folder (needs the DRIVE_* values below)
# gmail = read a connected Gmail mailbox (needs the GMAIL_* values below)
INBOX_PROVIDER=mock

# ── Google Drive folder monitoring (only when INBOX_PROVIDER=drive) ─────────
# Setup (create the service account + share the folder): see
# docs/drive-intake-setup.md. Selecting `drive` without a folder id or key fails
# fast at startup — it never silently falls back to the demo set.

# Folder id from the Drive URL:
#   https://drive.google.com/drive/folders/<THIS_IS_THE_FOLDER_ID>
DRIVE_FOLDER_ID=

# Service-account key. Two forms are accepted:
#   • Inline JSON (recommended here) — paste the WHOLE key on ONE line, starting
#     with `{`. No surrounding quotes. Example:
#       GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"…",…}
#   • Absolute path to a key file you have mounted into the container yourself.
GOOGLE_APPLICATION_CREDENTIALS=

# How often the poller sidecar re-checks the folder/mailbox, in seconds.
INBOX_POLL_INTERVAL=60

# ── Google Sheets ledger output (filed items append here) ───────────────────
# Setup (service account + spreadsheet): see docs/gmail-sheets-setup.md. Leave
# both values below empty to use the offline StubSheetsClient (no network) —
# filed items are recorded in Postgres but no real Sheet is written.

# Spreadsheet id from the Sheet's URL (…/spreadsheets/d/<THIS_IS_THE_ID>/edit),
# or leave empty to have the first filed item CREATE a new spreadsheet titled
# "Solopreneur Ledger" (its id is then fixed for the process's lifetime — set
# this once you know it, so restarts append to the same sheet).
SHEETS_SPREADSHEET_ID=

# Reuses GOOGLE_APPLICATION_CREDENTIALS above (a service account with the
# `drive.file` scope — it owns the sheet it creates). A dedicated Sheets-only
# key works too; just point this env var's consumer, GOOGLE_APPLICATION_CREDENTIALS,
# at whichever key you use.

# ── Gmail mailbox monitoring (only when INBOX_PROVIDER=gmail) ───────────────
# Setup (OAuth client, consent screen, one-time refresh-token mint): see
# docs/gmail-sheets-setup.md. Personal Gmail can't use a service account, so
# this is a per-user OAuth connection, not a shared credential. Selecting
# `gmail` without the three required values below fails fast at startup — it
# never silently falls back to the demo set.

# OAuth client id/secret ("Desktop app" type) from the Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Long-lived refresh token minted ONCE by:
#   python -m backend.tools.gmail_oauth_setup /path/to/client_secret.json
# Keep the OAuth consent screen in single-user "In production" mode (NOT
# "Testing", which expires this token after 7 days).
GMAIL_REFRESH_TOKEN=

# Fernet key encrypting the refresh token at rest in Postgres. Optional —
# without it (or without the `cryptography` package installed) the token is
# simply never persisted; the app re-reads GMAIL_REFRESH_TOKEN above on every
# restart instead. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_TOKEN_ENC_KEY=

# Label GmailInbox.on_processed would apply if this integration ever gains
# Gmail *modify* scope. Not yet actionable — the integration is deliberately
# gmail.readonly only (least privilege), so processed messages are never
# labeled or archived. Safe to leave empty.
GMAIL_LABEL=

# Tax year to anchor the first-connect backfill (after:<year>/01/01). Defaults
# to the current year if left empty.
GMAIL_TAX_YEAR=
