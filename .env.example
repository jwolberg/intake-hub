# IntakeHub configuration — copy to `.env`, fill in, then `docker compose up`.
#
#   cp .env.example .env
#
# `.env` is gitignored and auto-loaded by Docker Compose. Every value is optional;
# the defaults run the offline demo (mock inbox, no network). To monitor your own
# Google Drive folder, set INBOX_PROVIDER=drive and the DRIVE_* values below, then
# start the stack WITH the poller: `docker compose --profile drive up -d --build`.

# ── LLM extraction ──────────────────────────────────────────────────────────
# Anthropic key for model-derived extraction/confidence. Required in practice for
# Drive monitoring: real PDFs have no structured block, so without a key every
# invoice extracts blank and holds. Leave empty to use the offline stand-in (only
# parses the controlled sample PDFs).
ANTHROPIC_API_KEY=

# ── Inbox source ────────────────────────────────────────────────────────────
# mock  = offline demo set (default)
# drive = monitor a Google Drive folder (needs the three DRIVE_* values below)
INBOX_PROVIDER=mock

# ── Google Drive folder monitoring (only when INBOX_PROVIDER=drive) ─────────
# Setup (create the service account + share the folder): see
# docs/drive-intake-setup.md. Selecting `drive` without a folder id or key fails
# fast at startup — it never silently falls back to the demo set.

# Folder id from the Drive URL:
#   https://drive.google.com/drive/folders/<THIS_IS_THE_FOLDER_ID>
DRIVE_FOLDER_ID=

# Service-account key. Two forms are accepted:
#   • Inline JSON (recommended here) — paste the WHOLE key on ONE line, starting
#     with `{`. No surrounding quotes. Example:
#       GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account","project_id":"…",…}
#   • Absolute path to a key file you have mounted into the container yourself.
GOOGLE_APPLICATION_CREDENTIALS=

# How often the poller sidecar re-checks the folder, in seconds.
INBOX_POLL_INTERVAL=60
